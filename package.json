{
  "name": "study-cards",
  "version": "0.1.0",
  "private": true,
  "description": "A compact desktop study card app for structured learning notes.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "oauth:configure": "node scripts/configure-oauth.cjs",
    "build": "vite build",
    "package:win": "npm run build && electron-builder --win nsis dir --x64",
    "typecheck": "tsc --noEmit && npm run typecheck:electron",
    "start": "npm run build && electron .",
    "test": "node --test electron/*.test.cjs",
    "typecheck:electron": "tsc --allowJs --checkJs --noEmit --skipLibCheck --target es2022 --module node16 --moduleResolution node16 electron/main.cjs"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "build": {
    "appId": "app.studycards.local",
    "productName": "学习卡片",
    "asar": true,
    "icon": "build/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "build/icon.ico",
      "electron/**/*",
      "!electron/*.test.cjs",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
